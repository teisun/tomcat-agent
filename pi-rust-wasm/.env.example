# PI-WASM 环境变量示例
# 复制为 .env 后按需取消注释并填写，勿提交 .env（已加入 .gitignore）。

# ---------- LLM 必填 ----------
# OpenAI 兼容 API 密钥（必填，单测与 LLM 调用均依赖）
OPENAI_API_KEY=

# ---------- 可选：代理 ----------
# 未在 config 中设置 llm.proxy 时，reqwest 会自动读取以下环境变量（与 curl 一致）
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890

# 显式指定 LLM 代理（覆盖上述，与 config 中 llm.proxy 等效）
# PI_WASM__LLM__PROXY=http://127.0.0.1:7890

# ---------- 可选：降级 API Base ----------
# 主 API 不通时自动重试的备用 base
# PI_WASM__LLM__API_BASE_FALLBACK=https://api.chatanywhere.tech

# ---------- 可选：Wasm / QuickJS（feature wasmedge）----------
# run_script 依赖 wasmedge_quickjs.wasm；可通过 config [wasm] quickjs_path 或环境变量指定。环境变量覆盖 config。
# PI_WASM__WASM__QUICKJS_PATH=path/to/wasmedge_quickjs.wasm
# 未设置上述时，可回退使用（与 config 合并后的值优先）：
# WASMEDGE_QUICKJS_PATH=path/to/wasmedge_quickjs.wasm
