# PI-AWSM 配置示例
# 复制为 config.toml 后按需修改，通过 load_config(Some(Path::new("config.toml"))) 加载。
# 环境变量 PI_AWSM__*（如 PI_AWSM__LLM__PROXY）会覆盖同名字段。

[log]
level = "info"
file_enabled = false
file_path = "pi_awsm.log"
file_roll_size_mb = 10

[llm]
provider = "openai"
# api_base 不填则默认 https://api.openai.com
# api_key_env 不填则从环境变量 OPENAI_API_KEY 读取
default_model = "gpt-4o-mini"
max_concurrent_requests = 4
retry_count = 3
stream_timeout_sec = 60
# 可选：显式代理；不填时 reqwest 使用环境变量 HTTPS_PROXY/HTTP_PROXY
# proxy = "http://127.0.0.1:7890"
# 可选：主 API 不通时自动重试的备用 base
# api_base_fallback = "https://api.chatanywhere.tech"

[storage]
sessions_dir = "~/.pi/agent/sessions"

[plugin]
plugins_dir = "~/.pi/agent/plugins"
auto_load = []

[security]
default_plugin_permission_level = "restricted"
enable_audit_log = true
audit_log_retention_days = 90
enable_plugin_safety_scan = false

[primitive]
auto_confirm = false
require_approval_for_all_write = true
require_approval_for_all_bash = true
