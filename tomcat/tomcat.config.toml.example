# TOMCAT 配置示例
# 复制为 tomcat.config.toml 后按需修改。
# 环境变量 TOMCAT__*（如 TOMCAT__LLM__PROXY）会覆盖同名字段。

[log]
level = "warn"
file_enabled = false

[preflight]
# 进入 `tomcat chat` 后后台探测 search_files Tier1 依赖。
# 可通过 TOMCAT__PREFLIGHT__AUTO_INSTALL_SEARCH_TOOLS=false 覆盖。
auto_install_search_tools = true
# 进入 `tomcat chat` 后后台探测 git，可在后续 turn 中启用 checkpoint。
auto_install_git = true
# 是否显示 search_tools 预检的 [tools] 提示；默认后台执行但不打扰终端。
show_search_tools_ui = false
# 是否显示 git 预检的 [git] 提示；默认后台执行但不打扰终端。
show_git_ui = false

[checkpoint]
# 影子 git checkpoint 保留策略：最多保留最近 50 个、且不超过 7 天。
retention_max = 50
retention_days = 7

[llm]
# 这里只负责“选哪个模型”和全局运行时旋钮；
# 模型怎么连（api/provider/base_url/api_key_env）请写到 `models.toml`。
default_model = "gpt-5.4"
max_concurrent_requests = 4
retry_count = 3
stream_timeout_sec = 60
# proxy = "http://127.0.0.1:7890"
# api_base_fallback = "https://api.chatanywhere.tech"

[llm.files]
# OpenAI Files 上传兜底 TTL（秒）：
# - 默认 86400（24h）；
# - 0 表示不传 expires_after 字段（交给服务端默认策略）。
expires_after_seconds = 86400

[storage]
# 默认 ~/.tomcat/
# work_dir = "~/.tomcat/"

[agent]
id = "main"
# agent_dir = "~/.tomcat/agents/main/agent"
# workspace = "~/.tomcat/workspace-main"

[workspace]
workspace_roots = []

[plugin]
auto_load = []

[security]
default_plugin_permission_level = "restricted"
enable_audit_log = true
audit_log_retention_days = 90
enable_plugin_safety_scan = false

[wasm]

[primitive]
path_rules = []
bash_approval_required = []
bash_forbidden = []
auto_confirm = true

[tools.read]
max_bytes = 26214400

[tools.web_search]
# `auto` 会先尝试项目级 hosted web_search 模型；
# 若没有可用 hosted 候选，则默认交给官方 `web-search-backends` 插件，
# 再由插件内部 `autoOrder` 决定先试 mimo / tavily / brave / serper。
backend = "auto"
# 若想直接走官方插件里的 MiMo 后端，可改成：
# backend = "mimo"
# 若想直接点名插件里的 REST 后端，也可以写：
# backend = "tavily"
# backend = "brave"
# backend = "serper"
#
count = 5
# MiMo 通过 models.toml 里的 provider="mimo" 读取凭证：
# export MIMO_API_KEY="your-mimo-api-key"
# 插件里的 REST 后端通过 `pi.fetch` 读取凭证：
# export TAVILY_API_KEY="your-tavily-api-key"
# export BRAVE_API_KEY="your-brave-api-key"
# export SERPER_API_KEY="your-serper-api-key"
# 这些密钥不会进入 JS 沙箱明文，只能由插件 manifest 先报备后在 headers/body 中
# 用 `{{secret:NAME}}` 占位符请求宿主注入。
