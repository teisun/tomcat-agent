{
  "name": "tomcat-vscode-ext",
  "displayName": "Tomcat",
  "description": "Tomcat Agent Box, an AI coding agent in your VS Code sidebar.",
  "version": "0.1.16",
  "publisher": "tomcat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/teisun/tomcat-agent.git"
  },
  "tomcat": {
    "bundledCliVersion": "0.1.13"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "tomcat",
    "agent",
    "ai",
    "assistant",
    "sidebar",
    "vscode"
  ],
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.104.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "tomcat.restartServe",
        "title": "Tomcat: Restart Serve"
      },
      {
        "command": "tomcat.session.new",
        "title": "Tomcat: Start New Session"
      },
      {
        "command": "tomcat.session.list",
        "title": "Tomcat: List Sessions"
      },
      {
        "command": "tomcat.ui.focus",
        "title": "Tomcat: Focus Agent Box"
      },
      {
        "command": "tomcat.openSettings",
        "title": "Tomcat: Open Settings"
      },
      {
        "category": "Tomcat",
        "command": "tomcat.addSelectionToChat",
        "icon": "$(comment-add)",
        "title": "Add Selection to Tomcat Chat"
      },
      {
        "category": "Tomcat",
        "command": "tomcat.addFileToChat",
        "icon": "$(file-add)",
        "title": "Add File to Tomcat Chat"
      },
      {
        "category": "Tomcat Plan",
        "command": "tomcat.plan.build",
        "icon": "$(run)",
        "title": "Build Plan"
      },
      {
        "category": "Tomcat Plan",
        "command": "tomcat.plan.selectBuildModel",
        "icon": "$(sparkle)",
        "title": "Select Build Model"
      },
      {
        "category": "Tomcat Plan",
        "command": "tomcat.plan.viewAsPreview",
        "title": "Preview"
      },
      {
        "category": "Tomcat Plan",
        "command": "tomcat.plan.viewAsMarkdown",
        "title": "Markdown"
      },
      {
        "category": "Tomcat Plan",
        "command": "tomcat.plan.addSelectionToChat",
        "icon": "$(comment-add)",
        "title": "Add Selection to Tomcat Chat"
      }
    ],
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "tomcat-sidebar",
          "title": "TOMCAT",
          "icon": "media/tomcat.svg"
        }
      ]
    },
    "views": {
      "tomcat-sidebar": [
        {
          "id": "tomcat.chatView",
          "name": "TOMCAT",
          "type": "webview"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "tomcat.planPreview",
        "displayName": "Tomcat Plan Preview",
        "selector": [
          {
            "filenamePattern": "*.plan.md"
          }
        ],
        "priority": "default"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "tomcat.addSelectionToChat",
          "group": "navigation@20",
          "when": "editorHasSelection && editorTextFocus"
        }
      ],
      "explorer/context": [
        {
          "command": "tomcat.addFileToChat",
          "group": "navigation@20"
        }
      ],
      "editor/title": [
        {
          "command": "tomcat.plan.build",
          "group": "navigation@1",
          "when": "activeCustomEditorId == 'tomcat.planPreview' && config.tomcat.plan.toolbarStyle == 'native' && tomcat.plan.canBuild"
        },
        {
          "command": "tomcat.plan.selectBuildModel",
          "group": "navigation@2",
          "when": "activeCustomEditorId == 'tomcat.planPreview' && config.tomcat.plan.toolbarStyle == 'native'"
        },
        {
          "command": "tomcat.plan.viewAsMarkdown",
          "group": "1_tcplanmode@1",
          "when": "activeCustomEditorId == 'tomcat.planPreview'"
        },
        {
          "command": "tomcat.plan.viewAsPreview",
          "group": "1_tcplanmode@1",
          "when": "resourceFilename =~ /\\.plan\\.md$/ && activeEditor == 'workbench.editors.files.textFileEditor'"
        }
      ],
      "webview/context": [
        {
          "command": "tomcat.plan.addSelectionToChat",
          "group": "navigation@20",
          "when": "webviewId == 'tomcat.planPreview'"
        }
      ],
      "commandPalette": [
        {
          "command": "tomcat.plan.addSelectionToChat",
          "when": "activeCustomEditorId == 'tomcat.planPreview'"
        },
        {
          "command": "tomcat.plan.build",
          "when": "activeCustomEditorId == 'tomcat.planPreview' && tomcat.plan.canBuild"
        },
        {
          "command": "tomcat.plan.selectBuildModel",
          "when": "activeCustomEditorId == 'tomcat.planPreview'"
        },
        {
          "command": "tomcat.plan.viewAsPreview",
          "when": "resourceFilename =~ /\\.plan\\.md$/ && activeEditor == 'workbench.editors.files.textFileEditor'"
        },
        {
          "command": "tomcat.plan.viewAsMarkdown",
          "when": "activeCustomEditorId == 'tomcat.planPreview'"
        }
      ]
    },
    "keybindings": [
      {
        "command": "tomcat.addSelectionToChat",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "editorTextFocus && editorHasSelection"
      }
    ],
    "configuration": {
      "title": "Tomcat",
      "properties": {
        "tomcat.path": {
          "type": "string",
          "default": "tomcat",
          "description": "Path to the tomcat executable used to launch `tomcat serve --stdio`."
        },
        "tomcat.serve.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional CLI arguments passed to `tomcat serve --stdio`."
        },
        "tomcat.session.defaultCwd": {
          "type": "string",
          "default": "",
          "description": "Default working directory used when creating a new Tomcat session. Empty means the first workspace folder."
        },
        "tomcat.contextSearch.maxFiles": {
          "type": "integer",
          "minimum": 1,
          "default": 20000,
          "description": "Maximum workspace files indexed for `@` context search. Larger workspaces stop at this cap to keep the sidebar responsive."
        },
        "tomcat.plan.buildModel": {
          "type": "string",
          "default": "",
          "scope": "application",
          "description": "Model used when building a plan from the plan preview or a plan card. Empty means the session's current model is used."
        },
        "tomcat.plan.toolbarStyle": {
          "type": "string",
          "enum": [
            "hybrid",
            "native"
          ],
          "enumDescriptions": [
            "Hybrid (default): the editor title bar omits Build/model; a slim in-body action strip keeps the yellow Build button and the model dropdown.",
            "Full native: Build and model live on the editor title bar (icons + QuickPick); the body has no action strip."
          ],
          "default": "hybrid",
          "description": "Temporary A/B switch for where the plan preview shows its Build / model controls. Preview/Markdown always lives in the editor title bar overflow menu."
        }
      }
    }
  },
  "scripts": {
    "clean": "rm -rf out dist .vscode-test .wire-tmp *.vsix",
    "build:gui": "npm --prefix gui run build",
    "gen:wire": "tsx scripts/gen-wire.ts",
    "check:wire": "tsx scripts/gen-wire.ts --check",
    "compile": "tsc -p tsconfig.json",
    "build": "npm run gen:wire && npm run build:gui && npm run compile",
    "watch": "npm run gen:wire && tsc -watch -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test:unit:gui": "npm --prefix gui run test",
    "test:unit:core": "vitest run --maxWorkers 4 src",
    "test:unit": "npm run test:unit:core && npm run test:unit:gui",
    "test:integration": "vitest run --maxWorkers 1 tests",
    "test:e2e:vscode-devhost": "tsx scripts/run-vscode-devhost.ts",
    "test:e2e:vscode-install": "tsx scripts/run-vscode-install-e2e.ts",
    "test:e2e:webview-devhost": "tsx scripts/run-vscode-devhost.ts",
    "test:e2e:webview-install": "tsx scripts/run-vscode-install-e2e.ts",
    "test": "npm run test:unit",
    "gate:fast": "npm run lint && npm run test:unit",
    "gate:full": "tsx scripts/run-vscode-full-gate.ts",
    "package:vsix": "tsx scripts/package-vsix.ts",
    "verify:vsix": "tsx scripts/run-vscode-verify-vsix.ts"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.0.0",
    "@types/vscode": "1.101.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "mocha": "^11.7.6",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "diff": "9.0.0",
    "serialize-javascript": "7.0.6"
  }
}
