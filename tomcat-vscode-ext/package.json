{
  "name": "tomcat-vscode-ext",
  "displayName": "Tomcat",
  "description": "Tomcat Agent Box, an AI coding agent in your VS Code sidebar.",
  "version": "0.1.12",
  "publisher": "tomcat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/teisun/tomcat-agent.git"
  },
  "tomcat": {
    "bundledCliVersion": "0.1.11"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "tomcat",
    "agent",
    "ai",
    "assistant",
    "sidebar",
    "vscode"
  ],
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.104.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onChatParticipant:tomcat.tomcat",
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "tomcat.restartServe",
        "title": "Tomcat: Restart Serve"
      },
      {
        "command": "tomcat.session.new",
        "title": "Tomcat: Start New Session"
      },
      {
        "command": "tomcat.session.list",
        "title": "Tomcat: List Sessions"
      },
      {
        "command": "tomcat.ui.focus",
        "title": "Tomcat: Focus Agent Box"
      },
      {
        "command": "tomcat.openSettings",
        "title": "Tomcat: Open Settings"
      },
      {
        "category": "Tomcat",
        "command": "tomcat.addSelectionToChat",
        "icon": "$(comment-add)",
        "title": "Add Selection to Tomcat Chat"
      },
      {
        "category": "Tomcat",
        "command": "tomcat.addFileToChat",
        "icon": "$(file-add)",
        "title": "Add File to Tomcat Chat"
      }
    ],
    "chatParticipants": [
      {
        "id": "tomcat.tomcat",
        "name": "tomcat",
        "fullName": "Tomcat",
        "description": "Tomcat agent runtime backed by tomcat serve --stdio.",
        "commands": [
          {
            "name": "plan",
            "description": "Enter, build, or exit Tomcat plan mode."
          },
          {
            "name": "model",
            "description": "Switch the active Tomcat model."
          }
        ]
      }
    ],
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "tomcat-sidebar",
          "title": "TOMCAT",
          "icon": "media/tomcat.svg"
        }
      ]
    },
    "views": {
      "tomcat-sidebar": [
        {
          "id": "tomcat.chatView",
          "name": "TOMCAT",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "tomcat.addSelectionToChat",
          "group": "navigation@20",
          "when": "editorHasSelection && editorTextFocus"
        }
      ],
      "explorer/context": [
        {
          "command": "tomcat.addFileToChat",
          "group": "navigation@20"
        }
      ]
    },
    "keybindings": [
      {
        "command": "tomcat.addSelectionToChat",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "editorTextFocus && editorHasSelection"
      }
    ],
    "languageModelChatProviders": [
      {
        "vendor": "tomcat-test",
        "displayName": "Tomcat Test Model Vendor"
      }
    ],
    "configuration": {
      "title": "Tomcat",
      "properties": {
        "tomcat.path": {
          "type": "string",
          "default": "tomcat",
          "description": "Path to the tomcat executable used to launch `tomcat serve --stdio`."
        },
        "tomcat.serve.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional CLI arguments passed to `tomcat serve --stdio`."
        },
        "tomcat.session.defaultCwd": {
          "type": "string",
          "default": "",
          "description": "Default working directory used when creating a new Tomcat session. Empty means the first workspace folder."
        },
        "tomcat.contextSearch.maxFiles": {
          "type": "integer",
          "minimum": 1,
          "default": 20000,
          "description": "Maximum workspace files indexed for `@` context search. Larger workspaces stop at this cap to keep the sidebar responsive."
        },
        "tomcat.ui": {
          "type": "string",
          "enum": [
            "both",
            "participant",
            "webview"
          ],
          "default": "both",
          "description": "Choose whether Tomcat shows the native chat participant, the Tomcat Agent Box, or both."
        }
      }
    }
  },
  "scripts": {
    "clean": "rm -rf out dist .vscode-test .wire-tmp *.vsix",
    "build:gui": "npm --prefix gui run build",
    "gen:wire": "tsx scripts/gen-wire.ts",
    "check:wire": "tsx scripts/gen-wire.ts --check",
    "compile": "tsc -p tsconfig.json",
    "build": "npm run gen:wire && npm run build:gui && npm run compile",
    "watch": "npm run gen:wire && tsc -watch -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test:unit:gui": "npm --prefix gui run test",
    "test:unit:core": "vitest run --maxWorkers 4 src",
    "test:unit": "npm run test:unit:core && npm run test:unit:gui",
    "test:integration": "vitest run --maxWorkers 1 tests",
    "test:e2e:vscode-devhost": "tsx scripts/run-vscode-devhost.ts",
    "test:e2e:vscode-install": "tsx scripts/run-vscode-install-e2e.ts",
    "test:e2e:webview-devhost": "tsx scripts/run-vscode-devhost.ts",
    "test:e2e:webview-install": "tsx scripts/run-vscode-install-e2e.ts",
    "test": "npm run test:unit",
    "gate:fast": "npm run lint && npm run test:unit",
    "gate:full": "tsx scripts/run-vscode-full-gate.ts",
    "package:vsix": "tsx scripts/package-vsix.ts",
    "verify:vsix": "tsx scripts/run-vscode-verify-vsix.ts"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.0.0",
    "@types/vscode": "1.101.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "mocha": "^11.7.6",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "diff": "9.0.0",
    "serialize-javascript": "7.0.6"
  }
}
